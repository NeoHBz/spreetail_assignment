# Root URL of the backend API the frontend talks to.
# The API serves routes at the root (/auth, /groups, ...), so DO NOT add a /api suffix.
#
# Local dev (default if unset): http://localhost:3001
# On Vercel: set this in Project Settings -> Environment Variables to your deployed API root,
#   e.g. https://your-api-host.com        (correct)
#        https://your-api-host.com/api    (wrong -> requests would 404)
#
# NOTE: VITE_ vars are inlined into the client bundle at build time and are PUBLIC.
# Never put secrets here.
VITE_API_URL=http://localhost:3001
