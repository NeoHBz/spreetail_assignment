# Base URL of the backend API the frontend talks to.
# The API mounts all routes under /api (e.g. /api/auth, /api/groups, ...).
#
# Local dev (Vite proxy): leave as /api so the Vite dev proxy forwards
#   http://localhost:5173/api/* -> http://localhost:3001/api/*
#
# On Vercel or a custom host with a reverse proxy: set to /api if the proxy
# forwards /api/* to the API service, or to the full API base URL including /api,
#   e.g. https://your-api-host.com/api
#
# NOTE: VITE_ vars are inlined into the client bundle at build time and are PUBLIC.
# Never put secrets here.
VITE_API_URL=/api
