# Base URL of the backend API the frontend talks to.
# Local dev (default if unset): http://localhost:3001
# On Vercel, set this in Project Settings -> Environment Variables to your deployed API URL,
# e.g. https://your-api.onrender.com
#
# NOTE: VITE_ vars are inlined into the client bundle at build time and are PUBLIC.
# Never put secrets here.
VITE_API_URL=http://localhost:3001
